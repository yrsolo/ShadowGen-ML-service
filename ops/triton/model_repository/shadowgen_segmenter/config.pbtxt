name: "shadowgen_segmenter"
backend: "python"
max_batch_size: 4
input [
  {
    name: "image"
    data_type: TYPE_FP32
    dims: [ 3, -1, -1 ]
  }
]
output [
  {
    name: "mask"
    data_type: TYPE_FP32
    dims: [ 1, -1, -1 ]
  }
]
dynamic_batching {
  preferred_batch_size: [ 2, 4 ]
  max_queue_delay_microseconds: 15000
}
instance_group [
  {
    kind: KIND_CPU
    count: 1
  }
]
parameters {
  key: "model_id"
  value { string_value: "ZhengPeng7/BiRefNet" }
}
parameters {
  key: "resolution"
  value { string_value: "512" }
}
parameters {
  key: "mask_threshold"
  value { string_value: "0.5" }
}
parameters {
  key: "device"
  value { string_value: "cuda" }
}
parameters {
  key: "compile_enabled"
  value { string_value: "true" }
}
parameters {
  key: "compile_mode"
  value { string_value: "reduce-overhead" }
}
parameters {
  key: "compile_backend"
  value { string_value: "" }
}
parameters {
  key: "matmul_precision"
  value { string_value: "high" }
}
parameters {
  key: "local_files_only"
  value { string_value: "false" }
}

# Host GPU index exposed to the ML-service container.
# On the current workstation: 0 = RTX 2080 Ti, 1 = RTX 4090.
SERVICE_GPU_DEVICE=1

# The selected host GPU is remapped to cuda:0 inside the container.
SHADOWGEN_TARGET_DEVICE=cuda:0

SERVICE_HTTP_PORT=8000
SERVICE_IMAGE=shadowgen-ml-service:local
SERVICE_CONTAINER=shadowgen-ml-service

# Production-safe defaults. Enable the dev API only for local debugging.
SHADOWGEN_DEV_API_ENABLED=0
SHADOWGEN_DEV_SHUTDOWN_ENABLED=0

SHADOWGEN_DETECTOR_BACKEND_KIND=local
SHADOWGEN_SEGMENTER_BACKEND_KIND=local
SHADOWGEN_DEPTH_BACKEND_KIND=local
SHADOWGEN_NORMALS_BACKEND_KIND=local
SHADOWGEN_SHADOW_BACKEND_KIND=local
SHADOWGEN_SHADOW_MODEL_VARIANT=v2-diff

# Add private credentials only to .env, never to this tracked example.
# HF_TOKEN=
